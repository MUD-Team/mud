{
    "$schema": "https://raw.githubusercontent.com/TypeScriptToLua/TypeScriptToLua/master/tsconfig-schema.json",
    "compilerOptions": {      
      "target": "ESNext",
      "lib": ["ESNext"],
      "moduleResolution": "Node",      
      "strict": true,
      "rootDir": "./source",
      "outDir": "../bin/assets/core/script",
      "forceConsistentCasingInFileNames":true,
      "types": ["lua-types/5.4",  "@typescript-to-lua/language-extensions", "./types/mud.d.ts"]
    },
    "tstl": {
      "noHeader": true,
      "luaLibImport": "require",
      "luaTarget": "5.4",
      "sourceMapTraceback": true,
      "noImplicitSelf": true
    }
  }